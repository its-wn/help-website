---
layout: layouts/base.njk
title: Fernwartung
description: Laden Sie die RustDesk-Software herunter, damit ITS Waiblingen Ihnen per Fernzugriff helfen kann.
---

<div class="hero bg-base-200 py-12">
  <div class="hero-content text-center">
    <div class="max-w-xl">
      <h1 class="text-3xl font-bold text-body">ITS-Fernwartung</h1>
      <p class="mt-4 text-muted">
        Wir verwenden RustDesk für die Fernwartung. Hier finden Sie die Download-Links
        für Ihr Betriebssystem.
      </p>
    </div>
  </div>
</div>

<main class="mx-auto max-w-4xl px-4 py-12">
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    {% for download in rustdesk.downloads %}
    <div class="card card-border border-base-300 bg-base-100" data-os="{{ download.os }}">
      <div class="card-body items-center text-center">
        <div class="text-body">
          {% include "icons/" + download.icon + ".njk" %}
        </div>
        <h2 class="card-title text-body">{{ download.label }}</h2>
        <p class="text-muted text-sm">{{ download.description }}</p>
        <div class="card-actions mt-4">
          <a href="{{ download.url }}" class="btn btn-primary cursor-pointer no-underline">Download</a>
        </div>
        {% if download.altUrl %}
        <a href="{{ download.altUrl }}" class="link text-muted text-xs mt-2 cursor-pointer">{{ download.altLabel }}</a>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>

</main>

<script>
  ;(function () {
    var ua = navigator.userAgent
    var os

    if (/Win/.test(ua)) {
      os = 'windows'
    } else if (/Mac/.test(ua)) {
      os = 'macos-arm'
    }

    if (!os) return

    var card = document.querySelector('[data-os="' + os + '"]')
    if (!card) return

    card.classList.add('card-glow')
  })()
</script>
